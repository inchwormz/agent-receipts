{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://receipts.local/schemas/next_pass_packet.schema.json",
  "title": "NextPassPacket",
  "type": "object",
  "required": [
    "schema_version",
    "objective_id",
    "run_id",
    "branch_id",
    "pass_id",
    "objective",
    "evidence",
    "trusted_facts",
    "active_hypotheses",
    "contradictions",
    "recurring_failure_patterns",
    "candidate_actions",
    "verifier_findings",
    "open_questions",
    "raw_drilldown_refs",
    "halt_signals",
    "sources"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.1.0", "1.2.0", "2.0.0"] },
    "objective_id": { "type": "string" },
    "run_id": { "type": "string" },
    "branch_id": { "type": "string" },
    "pass_id": { "type": "string" },
    "objective": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceRecord" }
    },
    "trusted_facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/compiledFact" }
    },
    "active_hypotheses": {
      "type": "array",
      "items": { "$ref": "#/$defs/hypothesis" }
    },
    "contradictions": {
      "type": "array",
      "items": { "$ref": "#/$defs/contradiction" }
    },
    "recurring_failure_patterns": {
      "type": "array",
      "items": { "$ref": "#/$defs/recurringFailurePattern" }
    },
    "candidate_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidateAction" }
    },
    "verifier_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/verifierFinding" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "raw_drilldown_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "halt_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/haltSignal" }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "lane_digests": {
      "type": "array",
      "items": { "$ref": "#/$defs/laneDigest" }
    },
    "trust_assessments": {
      "type": "array",
      "items": { "$ref": "#/$defs/trustAssessment" }
    },
    "receipt_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/receiptEvent" }
    },
    "evidence_coverage": {
      "$ref": "#/$defs/evidenceCoverage"
    },
    "check_histories": {
      "type": "array",
      "items": { "$ref": "#/$defs/checkHistory" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceRef": {
      "type": "object",
      "required": ["source_id", "path", "kind", "hash", "hash_alg", "span", "observed_at"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        "hash_alg": { "type": "string", "enum": ["fnv1a-64"] },
        "hash_basis": { "type": "string", "enum": ["content", "label", "git"] },
        "span": { "type": ["string", "null"] },
        "observed_at": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "compiledFact": {
      "type": "object",
      "required": [
        "id",
        "statement",
        "objective_relevance",
        "novelty_gain",
        "needs_raw_drilldown",
        "source_ids"
      ],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "reported_confidence": { "type": "number" },
        "objective_relevance": { "type": "number" },
        "novelty_gain": { "type": "number" },
        "needs_raw_drilldown": { "type": "boolean" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "attestation": { "type": "string", "enum": ["verifier", "attested"] }
      },
      "additionalProperties": false
    },
    "evidenceRecord": {
      "type": "object",
      "required": ["id", "kind", "summary", "source_ids", "observed_at"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "summary": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "observed_at": { "type": "string" },
        "agent_id": { "type": "string" },
        "lane": { "type": "string" },
        "reported_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string" },
        "diff_ref": { "type": "string" },
        "span_before": { "type": "string" },
        "span_after": { "type": "string" },
        "claimed_agent_id": { "type": "string" },
        "claimed_lane": { "type": "string" },
        "provenance_warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "hypothesis": {
      "type": "object",
      "required": ["id", "statement", "verifier_score", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "reported_confidence": { "type": "number" },
        "verifier_score": { "type": ["number", "null"] },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "contradiction": {
      "type": "object",
      "required": ["id", "summary", "conflicting_item_ids", "severity", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "conflicting_item_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "additionalProperties": false
    },
    "recurringFailurePattern": {
      "type": "object",
      "required": ["id", "summary", "count", "last_seen_at", "impact", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "last_seen_at": { "type": "string" },
        "impact": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "candidateAction": {
      "type": "object",
      "required": [
        "id",
        "title",
        "rationale",
        "actionability_score",
        "decision_dependency_ids",
        "source_ids"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "rationale": { "type": "string" },
        "actionability_score": { "type": "number" },
        "decision_dependency_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "category": { "type": "string", "enum": ["adjudicate", "unblock", "resolve-finding", "verify-claim", "re-task-or-accept"] },
        "blocking": { "type": "boolean" },
        "resolved": { "type": "boolean" },
        "resolution_id": { "type": "string" },
        "suggested_argv": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "verifierFinding": {
      "type": "object",
      "required": ["id", "summary", "status", "verifier_score", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" },
        "verifier_score": { "type": "number" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "agent_id": { "type": "string" },
        "lane": { "type": "string" },
        "closure_reason": { "type": "string", "minLength": 1 },
        "finding_kind": { "type": "string", "enum": ["synthesis", "subagent-session", "bootstrap"] },
        "claimed_agent_id": { "type": "string" },
        "claimed_lane": { "type": "string" },
        "provenance_warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "laneDigest": {
      "type": "object",
      "required": ["lane", "records", "attested", "verifier", "asserted", "warnings", "contradictions", "read_recommendation"],
      "properties": {
        "lane": { "type": "string" },
        "agent_id": { "type": "string" },
        "records": { "type": "integer", "minimum": 0 },
        "attested": { "type": "integer", "minimum": 0 },
        "verifier": { "type": "integer", "minimum": 0 },
        "asserted": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "contradictions": { "type": "integer", "minimum": 0 },
        "read_recommendation": { "type": "string", "enum": ["skip-verified", "read-adjudicate", "read-unverified", "blocked"] },
        "drill_down": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "trustAssessment": {
      "type": "object",
      "required": ["subject_id", "integrity", "outcome", "applicability", "claim_status", "verifier_independent"],
      "properties": {
        "subject_id": { "type": "string" },
        "integrity": { "type": "string", "enum": ["signed", "hash_verified", "legacy_weak", "invalid"] },
        "outcome": { "type": "string", "enum": ["passed", "failed", "expected_failure", "unknown"] },
        "applicability": { "type": "string", "enum": ["current", "stale", "environment_mismatch", "unbound"] },
        "claim_status": { "type": "string", "enum": ["verified", "verifier_backed", "asserted", "refuted", "unknown"] },
        "verifier_independent": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "receiptEvent": {
      "type": "object",
      "required": ["receipt_id", "integrity", "outcome", "exit_code", "attempts_for_label"],
      "properties": {
        "receipt_id": { "type": "string" },
        "label": { "type": "string" },
        "integrity": { "type": "string", "enum": ["signed", "hash_verified", "legacy_weak", "invalid"] },
        "outcome": { "type": "string", "enum": ["passed", "failed", "expected_failure", "unknown"] },
        "exit_code": { "type": "integer" },
        "attempts_for_label": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "evidenceCoverage": {
      "type": "object",
      "required": ["total_claims", "verified_claims", "verifier_backed_claims", "asserted_claims", "refuted_claims"],
      "properties": {
        "total_claims": { "type": "integer", "minimum": 0 },
        "verified_claims": { "type": "integer", "minimum": 0 },
        "verifier_backed_claims": { "type": "integer", "minimum": 0 },
        "asserted_claims": { "type": "integer", "minimum": 0 },
        "refuted_claims": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "checkHistory": {
      "type": "object",
      "required": ["check_id", "target_claims", "first_result", "latest_result", "attempts", "failure_signatures", "transitions", "flake_rate"],
      "properties": {
        "check_id": { "type": "string" },
        "target_claims": { "type": "array", "items": { "type": "string" } },
        "first_result": { "type": "string", "enum": ["passed", "failed"] },
        "latest_result": { "type": "string", "enum": ["passed", "failed"] },
        "attempts": { "type": "integer", "minimum": 1 },
        "attempts_to_green": { "type": "integer", "minimum": 1 },
        "failure_signatures": { "type": "array", "items": { "type": "string" } },
        "transitions": { "type": "array", "items": { "type": "string" } },
        "flake_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "haltSignal": {
      "type": "object",
      "required": ["id", "kind", "contribution", "rationale", "source_ids"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "contribution": { "type": "number" },
        "rationale": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
